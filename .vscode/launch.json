{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "mccole as file",
            "type": "debugpy",
            "request": "launch",
            "program": "clui.py",
            "cwd": "${workspaceFolder}\\..\\mccole\\src",
            "args": [
                "build",
                "--src",
                "${workspaceFolder}",
                "--dst",
                "${workspaceFolder}\\docs"
            ]
        },
        {
            "name": "mccole as module",
            "type": "debugpy",
            "request": "launch",
            "module": "clui",
            "cwd": "${workspaceFolder}\\..\\mccole\\src",
        }
    ]
}