{
    "makefile.configureOnOpen": false,
    "editor.formatOnSave": false,
    "ruff.nativeServer": "on",
    "ruff.interpreter": [
        "${workspaceFolder}/.venv/Scripts/python.exe"
    ],
    "[python]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/__pycache__": true,
        "**/.ruff_cache": true,
        ".venv": true

    }
}